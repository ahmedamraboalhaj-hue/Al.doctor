rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════
    //  قواعد الأمان - منصة الدكتور في اللغة العربية
    //  تاريخ التحديث: 2026
    // ══════════════════════════════════════════════

    // ── طلاب السنتر: القراءة للكل، الكتابة مغلقة ──
    match /centerStudents/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── الطلاب: القراءة والكتابة مفتوحة (الأدمن بدون Firebase Auth) ──
    match /students/{docId} {
      allow read, write: if true;
    }

    // ── بيانات المنصة (الكورسات، الإعدادات): القراءة والكتابة مفتوحة ──
    match /platform_data/{docId} {
      allow read, write: if true;
    }

    // ── الدروس: القراءة والكتابة مفتوحة ──
    match /lessons/{docId} {
      allow read, write: if true;
    }

    // ── أكواد التفعيل: القراءة والكتابة مفتوحة ──
    match /activationCodes/{docId} {
      allow read, write: if true;
    }

    // ── الاختبارات: القراءة والكتابة مفتوحة ──
    match /quizzes/{docId} {
      allow read, write: if true;
    }

    // ── بنك الأسئلة: القراءة والكتابة مفتوحة ──
    match /question_bank/{docId} {
      allow read, write: if true;
    }

    // ── الفيديوهات: القراءة والكتابة مفتوحة ──
    match /videos/{docId} {
      allow read, write: if true;
    }

    // ── محاولات الاختبارات: القراءة والكتابة مفتوحة (للطلاب) ──
    match /quiz_attempts/{docId} {
      allow read, write: if true;
    }

    // ── نشاط الطلاب: القراءة والكتابة مفتوحة ──
    match /student_activity/{docId} {
      allow read, write: if true;
    }

    // ── اشتراكات الطلاب في الكورسات ──
    match /platform_courses/{docId}/{sub=**} {
      allow read, write: if true;
    }

    // ── طلبات الدفع ──
    match /payment_requests/{docId} {
      allow read, write: if true;
    }

    // ── طلبات الدفع (اسم بديل) ──
    match /paymentRequests/{docId} {
      allow read, write: if true;
    }

    // ── كل المجموعات الأخرى: مغلقة تماماً ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
